# Optional: advertise your LAN subnet from Proxmox. Leave empty unless you need LAN access.
# Example: 192.168.1.0/24
TS_ADVERTISE_ROUTES=""

# Optional: Proxmox LAN IP, used only for documentation/testing.
PVE_LAN_IP=""
