# Proxmox + Tailscale access config
# Edit these values before running scripts.

# Proxmox node details
PVE_HOSTNAME="pve"
PVE_TAILSCALE_IP="100.112.238.38"
PVE_WEB_PORT="8006"
PVE_MAGICDNS_NAME="pve.tailc2b3f5.ts.net"

# Tailscale options
TS_ACCEPT_DNS="true"
TS_ENABLE_SSH="true"
